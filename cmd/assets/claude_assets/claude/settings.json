{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$CLAUDE_PROJECT_DIR/.reasond_tmp\" \"$CLAUDE_PROJECT_DIR/.reasond/reasond_audits\" && cd \"$CLAUDE_PROJECT_DIR\" && reasond onboard"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/reasoning-audit-prompt.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/reasoning-audit-stop.sh\""
          }
        ]
      }
    ]
  }
}
