{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(git rev-parse --show-toplevel)\" && mkdir -p \"$ROOT/.reasond_tmp\" \"$ROOT/.reasond/reasond_audits\" && cd \"$ROOT\" && reasond onboard",
            "statusMessage": "Refreshing reasond workflow"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/reasoning-audit-prompt.sh\"",
            "statusMessage": "Saving user prompt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/reasoning-audit-stop.sh\"",
            "statusMessage": "Attaching prompt to audit",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
