{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$(git rev-parse --show-toplevel)/reasoning_logs\" && rm -f \"$(git rev-parse --show-toplevel)/reasoning_logs/.pending_prompt\"",
            "statusMessage": "Preparing reasoning log directory"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/reasoning-audit-prompt.sh\"",
            "statusMessage": "Saving user prompt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/reasoning-audit-stop.sh\"",
            "statusMessage": "Attaching prompt to audit",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
